{
  "short_name": "Api Spy",
  "name": "Api Spy - The node api debugger",
  "icons": {
    "16": "favicon.ico",
    "48": "favicon.ico",
    "128": "favicon.ico"
  },
  "version": "1.0",
  "manifest_version": 2,
  "browser_action": {
    "default_popup": "index.html"
  },
  "description": "Api Spy - The node api debugger",
  "devtools_page": "devpanel.html",
  "background": {
    "scripts": [
      "scripts/apiSpy.js",
      "scripts/devtools.js",
      "scripts/panel.js",
      "scripts/jquery-3.4.1.min.js",
      "scripts/moment.js"
    ]
  },
  "permissions": [
    "webRequest",
    "*://*/*",
    "webRequestBlocking",
    "<all_urls>",
    "tabs"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self';"
}