{
  "short_name": "Api Spy",
  "name": "Api Spy",
  "permissions": [
    "webRequest",
    "*://*/*"
  ],
  "content_security_policy": "script-src 'self' https://example.com; object-src 'self'",
  "version": "1.0",
    "manifest_version": 2,
    "browser_action": {
      "default_icon": {
        "16": "favicon.ico",
        "24": "favicon.ico",
        "32": "favicon.ico"
      },
      "default_title": "Api Spy",
      "default_popup": "index.html"
    }
}
